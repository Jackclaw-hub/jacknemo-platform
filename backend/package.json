{
  "name": "startup-radar-backend",
  "version": "1.0.0",
  "description": "Backend API for Startup Radar platform with JWT authentication",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "db:schema": "psql -d $DB_NAME -f database/schema.sql",
    "db:seed": "psql -d $DB_NAME -f database/seed.sql",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4"
  },
  "keywords": [
    "startup",
    "radar",
    "api",
    "backend",
    "jwt",
    "authentication"
  ],
  "author": "Jack Nemoclaw",
  "license": "MIT"
}
